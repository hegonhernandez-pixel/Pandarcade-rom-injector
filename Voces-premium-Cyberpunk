import asyncio
import os
from edge_tts import Communicate

# --- VOCES PREMIUM EN ESPAÑOL RECOMENDADAS ---
# "es-MX-AlvaroNeural" -> Voz de hombre, profunda, ideal para documentales (Recomendada)
# "es-MX-JorgeNeural"  -> Voz de hombre, tono de tutorial claro y directo
VOZ_SELECCIONADA = "es-MX-AlvaroNeural"

async def generar_audio_premium(texto, archivo_salida):
    """
    Utiliza el core neuronal avanzado de Microsoft de forma local
    para generar una locución humana y fluida sin sonar robótica.
    """
    print(f"🎤 Procesando locución humana premium -> {archivo_salida}...")
    communicate = Communicate(texto, VOZ_SELECCIONADA)
    await communicate.save(archivo_salida)
    print(f"[✅ EXCELENTE] Audio guardado con éxito en: {os.path.abspath(archivo_salida)}\n")

